# ─── App ────────────────────────────────────────────
APP_NAME=ChargebackDefender
DEBUG=false

# ─── Database ────────────────────────────────────────
# Render provides this automatically via Internal DB URL
DATABASE_URL=postgresql://user:password@localhost:5432/chargebackdb

# ─── JWT ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# ─── Anthropic ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Nas.io ──────────────────────────────────────────
NASIO_WEBHOOK_SECRET=your_nasio_webhook_secret
NASIO_COMMUNITY_SLUG=ecommerce-defender-room

# ─── Stripe (pay-per-dispute) ────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── OCR (optional upgrade) ──────────────────────────
GOOGLE_VISION_KEY=
USE_GOOGLE_VISION=false
